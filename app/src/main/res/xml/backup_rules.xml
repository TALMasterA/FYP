<?xml version="1.0" encoding="utf-8"?><!--
    Auto Backup rules for API 23-30 (§2.14 of docs/APP_SUGGESTIONS.md).

    The application sets android:allowBackup="false" in AndroidManifest.xml,
    so on a stock device this file is not consulted in practice. We still
    define explicit excludes for defence-in-depth: if a future build flips
    `allowBackup` on (e.g. for a regression-test build that needs Auto
    Backup), every file that contains user secrets, tokens, or local cache
    state must remain excluded.

    Excluded files cover:
      - secure_prefs.xml: EncryptedSharedPreferences holding Azure Speech
        tokens, FCM token cache, persistent rate-limit history.
      - *.preferences_pb: DataStore caches for translation, language
        detection, and word-bank metadata.
      - http_cache directory: OkHttp disk cache.
-->
<full-backup-content>
    <exclude domain="sharedpref" path="secure_prefs.xml" />
    <exclude domain="file" path="datastore/translation_cache.preferences_pb" />
    <exclude domain="file" path="datastore/language_detection_cache.preferences_pb" />
    <exclude domain="file" path="datastore/word_bank_cache.preferences_pb" />
    <exclude domain="file" path="datastore/seen_items.preferences_pb" />
    <exclude domain="file" path="http_cache" />
</full-backup-content>
