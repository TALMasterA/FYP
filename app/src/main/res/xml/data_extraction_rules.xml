<?xml version="1.0" encoding="utf-8"?><!--
    Data Extraction Rules for API 31+ (§2.14 of docs/APP_SUGGESTIONS.md).

    Like backup_rules.xml this file is normally inert because the manifest
    sets android:allowBackup="false". The explicit excludes below ensure that
    if cloud backup or device-to-device transfer is ever re-enabled, no file
    holding tokens, encrypted secrets, or local caches leaves the device.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="secure_prefs.xml" />
        <exclude domain="file" path="datastore/translation_cache.preferences_pb" />
        <exclude domain="file" path="datastore/language_detection_cache.preferences_pb" />
        <exclude domain="file" path="datastore/word_bank_cache.preferences_pb" />
        <exclude domain="file" path="datastore/seen_items.preferences_pb" />
        <exclude domain="file" path="http_cache" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="secure_prefs.xml" />
        <exclude domain="file" path="datastore/translation_cache.preferences_pb" />
        <exclude domain="file" path="datastore/language_detection_cache.preferences_pb" />
        <exclude domain="file" path="datastore/word_bank_cache.preferences_pb" />
        <exclude domain="file" path="datastore/seen_items.preferences_pb" />
        <exclude domain="file" path="http_cache" />
    </device-transfer>
</data-extraction-rules>
