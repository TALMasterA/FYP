rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================
    // User Settings: /users/{userId}/profile/settings
    // Owner-only with type validation on critical numeric/string fields.
    // historyViewLimit must be an integer in [30, 60].
    // fontSizeScale must be a float/int in [0.5, 2.0].
    // ============================================
    match /users/{userId}/profile/settings {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId
        && (!("historyViewLimit" in request.resource.data)
            || (request.resource.data.historyViewLimit is int
                && request.resource.data.historyViewLimit >= 30
                && request.resource.data.historyViewLimit <= 60))
        && (!("fontSizeScale" in request.resource.data)
            || (request.resource.data.fontSizeScale is number
                && request.resource.data.fontSizeScale >= 0.5
                && request.resource.data.fontSizeScale <= 2.0));
    }

    // ============================================
    // Translation History: /users/{userId}/history/{historyId}
    // Owner-only with core schema/type validation.
    // ============================================
    match /users/{userId}/history/{historyId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create, update: if request.auth != null
        && request.auth.uid == userId
        && isValidHistoryRecord(userId);
      allow delete: if request.auth != null && request.auth.uid == userId;

      function isValidLang(code) {
        return code is string && code.matches('^[a-z]{2}(-[A-Z]{2})?$');
      }

      function isValidHistoryRecord(uid) {
        return request.resource.data.userId == uid
          && request.resource.data.sourceText is string
          && request.resource.data.sourceText.size() > 0
          && request.resource.data.sourceText.size() <= 5000
          && request.resource.data.targetText is string
          && request.resource.data.targetText.size() > 0
          && request.resource.data.targetText.size() <= 5000
          && isValidLang(request.resource.data.sourceLang)
          && isValidLang(request.resource.data.targetLang)
          && request.resource.data.timestamp is timestamp;
      }
    }

    // ============================================
    // Learning Sheets: /users/{userId}/learning_sheets/{sheetId}
    // Owner-only with language/docId/count validation.
    // ============================================
    match /users/{userId}/learning_sheets/{sheetId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create, update: if request.auth != null
        && request.auth.uid == userId
        && isValidLearningSheet(sheetId);
      allow delete: if request.auth != null && request.auth.uid == userId;

      function isValidLang(code) {
        return code is string && code.matches('^[a-z]{2}(-[A-Z]{2})?$');
      }

      function isValidLearningSheet(id) {
        return isValidLang(request.resource.data.primaryLanguageCode)
          && isValidLang(request.resource.data.targetLanguageCode)
          && id == request.resource.data.primaryLanguageCode + '__' + request.resource.data.targetLanguageCode
          && request.resource.data.content is string
          && request.resource.data.content.size() > 0
          && request.resource.data.historyCountAtGenerate is int
          && request.resource.data.historyCountAtGenerate >= 1
          && request.resource.data.historyCountAtGenerate <= 1000000
          && request.resource.data.updatedAt is timestamp;
      }
    }

    // ============================================
    // Server-owned quiz versions: /users/{userId}/quiz_versions/{docId}
    // Readable by owner, writable only by admin SDK / Cloud Functions.
    // ============================================
    match /users/{userId}/quiz_versions/{docId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    // ============================================
    // User Data Subcollections
    // Users can only access their own subcollections.
    // Coin-related subcollections (user_stats/coins, coin_awards, last_awarded_quiz)
    // are READ-ONLY for clients — only the admin SDK (Cloud Functions like
    // awardQuizCoins and spendCoins) can write to them.
    // Note: awardQuizCoins enforces a server-side MAX_QUIZ_SCORE = 50 safety cap (quiz is fixed at 10 questions).
    // ============================================
    match /users/{userId}/{subCol}/{docId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId
        && subCol != 'coin_awards'
        && subCol != 'last_awarded_quiz'
        && subCol != 'history'
        && subCol != 'learning_sheets'
        && subCol != 'quiz_versions'
        && !(subCol == 'user_stats' && docId == 'coins')
        && !(subCol == 'profile' && docId == 'settings');
    }

    // ============================================
    // Block List: /users/{userId}/blocked_users/{blockedId}
    // Only the owner can read/write their block list.
    // Other users can read IF they are the blocked party (to check if they're blocked).
    // ============================================
    match /users/{userId}/blocked_users/{blockedId} {
      // Owner can fully manage their block list
      allow read, write: if request.auth != null && request.auth.uid == userId;
      // Blocked user can check if they are blocked (needed for UI block-status check)
      allow read: if request.auth != null && request.auth.uid == blockedId;
    }

    // ============================================
    // Main User Document: /users/{userId}
    // Two access patterns:
    // 1. Owner can read/write their own document
    // 2. Cross-user writes for unread message counters only
    // ============================================
    match /users/{userId} {
      // Allow owner to read/write their own document
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Allow cross-user writes for unread counters only
      // This covers both .update() and .set() with merge
      allow write: if request.auth != null
        && request.auth.uid != userId
        && onlyUpdatingUnreadCounters();
    }

    // Helper function to check if only unread counter fields are being modified
    function onlyUpdatingUnreadCounters() {
      // The app uses update() with DOT-NOTATION (e.g., "unreadPerFriend.{friendId}")
      // to avoid overwriting sibling entries in nested maps.
      // Falls back to set() with merge for document creation.
      //
      // When the document doesn't exist yet (resource == null):
      // - For new documents, check that we're only creating the allowed fields
      //
      // When the document exists (resource != null):
      // - Check that only the allowed fields are being modified
      //
      // Note: When using dot notation like "unreadPerFriend.{friendId}", Firestore treats
      // the entire map field 'unreadPerFriend' as changed, not individual subfields.
      //
      // Type validation: totalUnreadMessages must be a non-negative integer to prevent
      // a malicious sender from corrupting the counter with strings or negative values.

      return resource == null
        ? request.resource.data.keys().hasOnly(['totalUnreadMessages', 'unreadPerFriend'])
          && request.resource.data.totalUnreadMessages is int
          && request.resource.data.totalUnreadMessages >= 0
        : request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalUnreadMessages', 'unreadPerFriend'])
          && request.resource.data.totalUnreadMessages is int
          && request.resource.data.totalUnreadMessages >= 0;
    }

    // ============================================
    // Friends Feature - Shared Inbox
    // Allow authenticated users to CREATE (send) shared items into another user's inbox.
    // The sender's fromUserId must match their auth UID.
    // The recipient (owner) can read, update (accept/dismiss) via the owner rule above.
    // ============================================
    match /users/{userId}/shared_inbox/{itemId} {
      // Any authenticated user can send (create) a shared item to another user's inbox.
      // fromUserId in the document must match the authenticated sender.
      // toUserId must match the inbox owner path to prevent recipient mismatch.
      allow create: if request.auth != null
        && request.resource.data.fromUserId == request.auth.uid
        && request.resource.data.toUserId == userId;

      // Allow creating the content subcollection (e.g. for learning sheets).
      // The parent shared_inbox doc and content doc are written together in a batch,
      // so we cannot use get() to check the parent. Instead we validate that the
      // fromUserId field written into the content doc matches the authenticated sender.
      // This prevents any authenticated user from injecting content into another
      // user's inbox.
      match /content/{docId} {
        // Owner (recipient) can read the full content of shared items in their inbox.
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null
          && request.resource.data.fromUserId == request.auth.uid;
      }
    }

    // ============================================
    // Friends Feature - Public Profiles
    // Allow authenticated users to read public profiles of any user
    // ============================================
    match /users/{userId}/profile/public {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && isValidPublicProfile();

      // Public profile consistency guard:
      // - isDiscoverable must be boolean if present
      // - If discoverable=true, username must be 3-20 chars [a-zA-Z0-9_]
      function isValidPublicProfile() {
        let usernamePresent = "username" in request.resource.data;
        let usernameValid = usernamePresent
          ? (request.resource.data.username is string
             && request.resource.data.username.size() >= 3
             && request.resource.data.username.size() <= 20
             && request.resource.data.username.matches("^[A-Za-z0-9_]+$"))
          : true;

        let discoverablePresent = "isDiscoverable" in request.resource.data;
        let discoverableValid = discoverablePresent
          ? request.resource.data.isDiscoverable is bool
          : true;

        let discoverableRequiresUsername =
          discoverablePresent && request.resource.data.isDiscoverable == true
            ? (usernamePresent
               && request.resource.data.username is string
               && request.resource.data.username.size() >= 3
               && request.resource.data.username.size() <= 20
               && request.resource.data.username.matches("^[A-Za-z0-9_]+$"))
            : true;

        return usernameValid && discoverableValid && discoverableRequiresUsername;
      }
    }

    // ============================================
    // Friends Feature - Friends List
    // Allow users to read their own friends list
    // Also allow batch writes when accepting friend requests (both users get updated)
    // ============================================
    match /users/{userId}/friends/{friendId} {
      // Users can read their own friends
      allow read: if request.auth != null && request.auth.uid == userId;

      // Users can write to their own friends list
      allow write: if request.auth != null && request.auth.uid == userId;

      // Special case: Allow CREATING in friend's list when accepting friend request.
      // Only create is permitted (not update or delete) to prevent any authenticated user
      // from unilaterally modifying or removing entries in another user's friends list.
      // Unfriending and username updates are always done by the list owner via the rule above.
      allow create: if request.auth != null && request.auth.uid == friendId;
    }

    // ============================================
    // Feedback Collection (For feedback feature)
    // Authenticated users can submit feedback
    // ============================================
    match /feedback/{feedbackId} {
      // Allow authenticated users to create feedback
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.message is string
                    && request.resource.data.message.size() > 0
                    && request.resource.data.message.size() <= 5000;

      // Feedback is write-only for users (only admins should read - not implemented yet)
      allow read, update, delete: if false;
    }

    // ============================================
    // Friends Feature - Username Registry
    // ============================================
    match /usernames/{username} {
      allow read: if request.auth != null;
      allow create: if request.auth != null 
        && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null 
        && resource.data.userId == request.auth.uid;
    }

    // ============================================
    // Friends Feature - User Search Index
    // ============================================
    match /user_search/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && isValidUserSearchDoc();

      // Search index consistency guard:
      // - isDiscoverable is required and must be boolean
      // - discoverable=true requires non-empty canonical username and lowercase key
      // - discoverable=false may omit username_lowercase (cleanup-safe)
      function isValidUserSearchDoc() {
        let hasDiscoverable = "isDiscoverable" in request.resource.data;
        let discoverableIsBool = hasDiscoverable && request.resource.data.isDiscoverable is bool;

        let usernameValid = !request.resource.data.isDiscoverable
          || ("username" in request.resource.data
              && request.resource.data.username is string
              && request.resource.data.username.size() >= 3
              && request.resource.data.username.size() <= 20
              && request.resource.data.username.matches("^[A-Za-z0-9_]+$"));

        let lowercaseValid = !request.resource.data.isDiscoverable
          || ("username_lowercase" in request.resource.data
              && request.resource.data.username_lowercase is string
              && request.resource.data.username_lowercase == request.resource.data.username.lower());

        return hasDiscoverable && discoverableIsBool && usernameValid && lowercaseValid;
      }
    }

    // ============================================
    // Friends Feature - Friend Requests
    // ============================================
    match /friend_requests/{requestId} {
      // Read if sender or receiver
      allow read: if request.auth != null && (
        resource.data.fromUserId == request.auth.uid ||
        resource.data.toUserId == request.auth.uid
      );

      // Create if authenticated, is sender, AND sender is not blocked by recipient.
      // This server-side check prevents a client from bypassing the client-side block check.
      allow create: if request.auth != null
        && request.resource.data.fromUserId == request.auth.uid
        && request.resource.data.status == "PENDING"
        && !exists(/databases/$(database)/documents/users/$(request.resource.data.toUserId)/blocked_users/$(request.auth.uid));

      // Update: two cases are allowed:
      // 1. Sender can rename their username on pending requests.
      // 2. Recipient can update status to ACCEPTED or REJECTED (and optionally set
      //    rejectionReason and updatedAt). This supports the updated accept/reject flow
      //    that preserves request history instead of deleting the document.
      allow update: if request.auth != null && (
        // Sender updates their displayed username on a pending request
        (resource.data.fromUserId == request.auth.uid &&
         resource.data.status == "PENDING" &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(["fromUsername"])) ||
        // Recipient accepts or rejects the request
        (resource.data.toUserId == request.auth.uid &&
         resource.data.status == "PENDING" &&
         (request.resource.data.status == "ACCEPTED" || request.resource.data.status == "REJECTED") &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(["status", "rejectionReason", "updatedAt"]))
      );

      // Allow sender or receiver to delete ANY of their requests (any status).
      // This covers:
      //   - Recipient accepting (deletes the PENDING request atomically with friend creation)
      //   - Cleanup of stale docs when unfriending (so re-add always works)
      //   - Safety: sender can retract a PENDING request by deleting instead of cancelling
      allow delete: if request.auth != null && (
        resource.data.fromUserId == request.auth.uid ||
        resource.data.toUserId == request.auth.uid
      );
    }

    // ============================================
    // Friends Feature - Chat Messages
    // ============================================
    match /chats/{chatId}/messages/{messageId} {
      // Read if user is in the chatId (chatId format: "userId1_userId2")
      // This avoids extra document reads by parsing the chatId
      function isParticipantFromChatId() {
        let userIds = chatId.split('_');
        return request.auth.uid == userIds[0] || request.auth.uid == userIds[1];
      }

      // Read if participant in chat (determined from chatId)
      allow read: if request.auth != null && isParticipantFromChatId();

      // Create if participant and sender matches auth.uid
      allow create: if request.auth != null 
        && isParticipantFromChatId()
        && request.resource.data.senderId == request.auth.uid
        && request.resource.data.content.size() > 0
        && request.resource.data.content.size() <= 2000
        && (!('senderUsername' in request.resource.data)
            || (request.resource.data.senderUsername is string
                && request.resource.data.senderUsername.size() <= 20));

      // Update only allowed for marking as read
      allow update: if request.auth != null 
        && isParticipantFromChatId()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);

      // Allow participants to delete messages (cleanup when unfriending)
      allow delete: if request.auth != null && isParticipantFromChatId();
    }

    // ============================================
    // Friends Feature - Chat Metadata
    // ============================================
    match /chats/{chatId}/metadata/info {
      // Helper function to check if user is participant based on chatId format
      function isParticipantFromChatId() {
        // chatId format is "userId1_userId2" (sorted)
        let userIds = chatId.split('_');
        return request.auth.uid == userIds[0] || request.auth.uid == userIds[1];
      }

      // Allow read if user is participant
      allow read: if request.auth != null && (
        // Check existing participants list if document exists
        (resource != null && request.auth.uid in resource.data.participants) ||
        // Or infer from chatId pattern
        isParticipantFromChatId()
      );

      // Allow write if user is participant
      allow write: if request.auth != null && (
        // Check participants field in the data being written (if present)
        (request.resource.data.participants != null &&
         request.auth.uid in request.resource.data.participants) ||
        // Or infer from chatId pattern (for updates that don't include participants field)
        isParticipantFromChatId()
      )
      // Keep unreadCount map-typed when present.
      && (!('unreadCount' in request.resource.data)
          || request.resource.data.unreadCount is map);
    }

    // ============================================
    // Friends Feature - Chat Cleared Timestamps
    // Each user stores their own "clearedAt" timestamp so messages before
    // that time are hidden from their view.  Only the owner can read/write
    // their own cleared document.
    // ============================================
    match /chats/{chatId}/cleared/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ============================================
    // Rate Limits: Admin-only (Cloud Functions write via admin SDK).
    // Explicitly block all client-side access.
    // ============================================
    match /rate_limits/{userId} {
      allow read, write: if false;
    }

    // ============================================
    // DEFAULT: Deny all other access
    // ============================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}